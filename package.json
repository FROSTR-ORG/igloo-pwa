{
  "name": "igloo-pwa",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "npm --prefix ../igloo-ui run build",
    "build:browser-wasm": "node ./scripts/sync-bridge-wasm.mjs",
    "build:app": "tsc && vite build",
    "dev": "if [ \"${FROSTR_TEST_PREPARED:-0}\" = \"1\" ]; then vite --host 0.0.0.0 --port 1430 --strictPort; else npm run build:ui && npm run build:browser-wasm && vite --host 0.0.0.0 --port 1430 --strictPort; fi",
    "build": "npm run build:ui && npm run build:browser-wasm && npm run build:app",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "test:unit": "vitest run",
    "test:e2e": "npm --prefix ../../test run test:e2e:igloo-pwa",
    "test": "npm run test:unit"
  },
  "dependencies": {
    "igloo-shared": "file:../igloo-shared",
    "igloo-ui": "file:../igloo-ui",
    "nostr-tools": "^2.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.3"
  }
}
